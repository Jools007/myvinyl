{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/enrich.ts": {
      "maxDuration": 10,
      "includeFiles": "server/**"
    },
    "api/album-info.ts": {
      "maxDuration": 10
    },
    "api/health.ts": {
      "maxDuration": 15
    },
    "api/discogs/release/[id].ts": {
      "maxDuration": 15
    },

    "api/discogs/collection.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/discogs/search", "destination": "/api/health" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}