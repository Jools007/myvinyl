{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {

    "api/album-info.js": {
      "maxDuration": 10
    },
    "api/album-character.js": {
      "maxDuration": 15
    },
    "api/health.ts": {
      "maxDuration": 15
    },
    "api/enrich.js": {
      "maxDuration": 25
    },
    "api/discogs/collection.js": {
      "maxDuration": 30
    },
    "api/discogs/price-suggestions.js": {
      "maxDuration": 15
    },
    "api/image.js": {
      "maxDuration": 10
    },
    "api/play/audio.js": {
      "maxDuration": 22
    },
    "api/spotify/audio.js": {
      "maxDuration": 15
    },
    "api/lastfm/vibe.js": {
      "maxDuration": 10
    },
    "api/lastfm/similar.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/discogs/search", "destination": "/api/health" },
    { "source": "/api/discogs/release/:id", "destination": "/api/health?releaseId=:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}