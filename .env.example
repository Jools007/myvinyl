# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Discogs — https://www.discogs.com/settings/developers
# Server-only (enrichment API, image proxy). Not exposed to the browser.
DISCOGS_TOKEN=

# Client-side Discogs API (search, release detail, collection import).
# Must use the VITE_ prefix — Vite only exposes env vars that start with VITE_.
VITE_DISCOGS_TOKEN=

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — improves YouTube search reliability (Google Cloud YouTube Data API v3)
YOUTUBE_API_KEY=