# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Use the publishable key (sb_publishable_…) or legacy anon JWT from API Keys.
# If auth fails with 403 on /auth/v1/user, try the legacy anon key or clear localhost storage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Discogs — https://www.discogs.com/settings/developers
# Server-only (enrichment API, image proxy). Not exposed to the browser.
DISCOGS_TOKEN=

# Discogs OAuth app credentials — marketplace price suggestions (Insights valuation).
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
# Optional — user OAuth tokens if Discogs requires authorized access for your app.
DISCOGS_OAUTH_ACCESS_TOKEN=
DISCOGS_OAUTH_ACCESS_TOKEN_SECRET=

# Client-side Discogs API (search, release detail, collection import).
# Must use the VITE_ prefix — Vite only exposes env vars that start with VITE_.
VITE_DISCOGS_TOKEN=

# Last.fm — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — improves YouTube search when InnerTube is rate-limited.
# Create at https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3).
# Sync to Vercel: node scripts/sync-vercel-env.mjs
YOUTUBE_API_KEY=